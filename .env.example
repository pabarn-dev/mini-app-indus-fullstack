# Copy to .env at the repo root: `cp .env.example .env`
# This file is the single source of truth, shared by docker-compose and apps/api.

# --- PostgreSQL (consumed by docker-compose.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=industrial_production_pilot
# Host port (5433 to avoid clashing with a local PostgreSQL on 5432).
POSTGRES_PORT=5433

# --- Backend (apps/api) — Prisma connection string ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/industrial_production_pilot?schema=public"

# --- API ---
PORT=3001
